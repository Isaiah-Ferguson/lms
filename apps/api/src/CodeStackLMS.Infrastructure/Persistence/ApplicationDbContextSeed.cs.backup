    private static async Task SeedCourseAsync(
        ApplicationDbContext context,
        Guid cohortId,
        string defaultZoomUrl,
        string title,
        string description,
        (int weekNumber, string weekTitle, string dateRange, string[] topics)[] weeks,
        (string title, string body, string announcedAt, string tag)[] announcements)
    {
        var course = new Course
        {
            Id = Guid.NewGuid(),
            Title = title,
            Description = description,
            CreatedAt = DateTime.UtcNow,
        };
        context.Courses.Add(course);

        context.CohortCourses.Add(new CohortCourse
        {
            Id = Guid.NewGuid(),
            CohortId = cohortId,
            CourseId = course.Id,
        });

        for (var i = 0; i < weeks.Length; i++)
        {
            var (weekNumber, weekTitle, dateRange, topics) = weeks[i];
            var module = new Module
            {
                Id = Guid.NewGuid(),
                CourseId = course.Id,
                Title = weekTitle,
                Order = i + 1,
                WeekNumber = weekNumber,
                DateRange = dateRange,
                ZoomUrl = defaultZoomUrl,
                CreatedAt = DateTime.UtcNow,
            };
            context.Modules.Add(module);

            for (var j = 0; j < topics.Length; j++)
            {
                context.Lessons.Add(new Lesson
                {
                    Id = Guid.NewGuid(),
                    ModuleId = module.Id,
                    Title = topics[j],
                    Order = j + 1,
                    Type = LessonType.Text,
                    CreatedAt = DateTime.UtcNow,
                });
            }
        }

        foreach (var (annTitle, body, announcedAt, tag) in announcements)
        {
            context.Announcements.Add(new Announcement
            {
                Id = Guid.NewGuid(),
                CourseId = course.Id,
                Title = annTitle,
                Body = body,
                Tag = tag,
                AnnouncedAt = DateTime.Parse(announcedAt, null, System.Globalization.DateTimeStyles.RoundtripKind),
                CreatedAt = DateTime.UtcNow,
            });
        }

        await context.SaveChangesAsync();
    }

    private static async Task SeedAssignmentsAsync(ApplicationDbContext context)
    {
        Console.WriteLine("=== Starting Assignment Seeding ===");
        var courses = await context.Courses.ToListAsync();
        Console.WriteLine($"Found {courses.Count} courses");
        
        foreach (var course in courses)
        {
            Console.WriteLine($"Checking course: {course.Title} (ID: {course.Id})");
            var modules = await context.Modules
                .Where(m => m.CourseId == course.Id)
                .OrderBy(m => m.Order)
                .ToListAsync();
            
            Console.WriteLine($"  Found {modules.Count} modules for {course.Title}");

            var existingAssignments = await context.Assignments
                .AnyAsync(a => modules.Select(m => m.Id).Contains(a.ModuleId));
            
            Console.WriteLine($"  Existing assignments: {existingAssignments}");

            if (!existingAssignments && modules.Count > 0)
            {
                Console.WriteLine($"  Creating {Math.Min(5, modules.Count)} assignments for {course.Title}");
                // Add one assignment per module (limit to first 5 to avoid too many)
                foreach (var module in modules.Take(5))
                {
                    var assignment = new Assignment
                    {
                        Id = Guid.NewGuid(),
                        ModuleId = module.Id,
                        Title = $"{module.Title} - Assignment",
                        Instructions = $"Complete the exercises for {module.Title}.",
                        DueDate = DateTime.UtcNow.AddDays(7 * module.Order),
                        RubricJson = "{\"maxScore\":100,\"criteria\":[{\"name\":\"Completion\",\"points\":50},{\"name\":\"Quality\",\"points\":50}]}",
                        CreatedAt = DateTime.UtcNow
                    };
                    context.Assignments.Add(assignment);
                    Console.WriteLine($"    Added: {assignment.Title}");
                }
            }
            else
            {
                Console.WriteLine($"  Skipping {course.Title} - already has assignments or no modules");
            }
        }
        
        await context.SaveChangesAsync();
        Console.WriteLine("=== Assignment Seeding Complete ===");
    }
}
